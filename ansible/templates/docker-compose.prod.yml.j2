version: '3.8'

services:
  nginx:
    image: nginx:alpine
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - static_volume:/app/staticfiles:ro  
    ports:
      - "80:80"
      - "443:443"
    depends_on:
      gunicorn:
        condition: service_healthy
      daphne:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - app_network

  gunicorn:
    image: "{{ ecr_registry }}/{{ ecr_repo }}:{{ ecr_image_tag }}"
    command: >
      sh -c "python manage.py migrate --noinput && 
             python manage.py collectstatic --noinput --verbosity 3 &&
             gunicorn mysite.wsgi:application --bind 0.0.0.0:8000 --workers 4 --threads 2"
    env_file:
      - .env.prod
    volumes:
      - static_volume:/app/staticfiles  
    restart: unless-stopped
    networks:
      - app_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/"]   # or use a dedicated /health/ endpoint
      interval: 5s
      timeout: 3s
      retries: 5
      start_period: 10s

  daphne:
    image: "{{ ecr_registry }}/{{ ecr_repo }}:{{ ecr_image_tag }}"
    command: daphne -b 0.0.0.0 -p 8001 mysite.asgi:application
    env_file:
      - .env.prod
    restart: unless-stopped
    networks:
      - app_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8001/"]   # Daphne should respond to HTTP GET
      interval: 5s
      timeout: 3s
      retries: 5
      start_period: 10s
volumes:
  static_volume:
networks:
  app_network:
    driver: bridge