pipeline {
    agent any

    environment {
        AWS_ACCOUNT_ID = '822417885273'
        AWS_REGION = 'us-east-1'
        ECR_REPO_NAME = 'multivendor'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_NAME = "${ECR_REGISTRY}/${ECR_REPO_NAME}"
        REGISTRY_URL = "https://${ECR_REGISTRY}"
        REGISTRY_CREDENTIALS = 'ecr:us-east-1:awscreds'
    }

    stages {
        stage('Build Docker Image') {
            steps {
                script {
                    dockerImage = docker.build("${IMAGE_NAME}:${BUILD_NUMBER}", ".")
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    docker.withRegistry(REGISTRY_URL, REGISTRY_CREDENTIALS) {
                        dockerImage.push()
                    }
                }
            }
        }

        stage('Test SSH Connection') {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'SSH_KEY_FILE')]) {
                    withEnv(["SSH_KEY_FILE=${SSH_KEY_FILE}"]) {
                        sh '''
                            ssh -i "$SSH_KEY_FILE" -o StrictHostKeyChecking=no ubuntu@172.31.42.93 "echo OK"
                        '''
                    }
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                withCredentials([
                    file(credentialsId: 'evd-prod-file', variable: 'SECRET_ENV_FILE'),
                    file(credentialsId: 'env-redis-prod', variable: 'SECRET_ENV_FILE_REDIS'),
                    sshUserPrivateKey(
                        credentialsId: 'host-ssh-key',
                        keyFileVariable: 'SSH_KEY_FILE',
                        usernameVariable: 'SSH_USER'
                    )
                ]) {
                    withEnv([
                        "ANSIBLE_HOST_KEY_CHECKING=False",
                        "SSH_KEY_FILE=${SSH_KEY_FILE}",
                        "SECRET_ENV_FILE=${SECRET_ENV_FILE}",
                        "SECRET_ENV_FILE_REDIS=${SECRET_ENV_FILE_REDIS}"
                    ]) {
                        sh '''
                            ansible-playbook ansible/deploy.yml \
                            -i ansible/inventory/inventory.yml \
                            --private-key "$SSH_KEY_FILE" \
                            --extra-vars "secret_file_path=$SECRET_ENV_FILE secret_file_path_redis=$SECRET_ENV_FILE_REDIS"
                        '''
                    }
                }
            }
        }

        stage('Clean up') {
            steps {
                sh "docker image prune -f || true"
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed!"
        }
        success {
            echo "Pipeline succeeded! Image ${IMAGE_NAME}:${BUILD_NUMBER} deployed."
        }
    }
}